{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the PinShot main, overlay, and pin windows.",
  "windows": ["main", "overlay-*", "pin-*", "editor", "settings", "preview"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-size",
    "core:window:allow-inner-size",
    "core:window:allow-scale-factor"
  ]
}
